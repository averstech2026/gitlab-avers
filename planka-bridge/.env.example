# --- Planka ---
# API (из Docker-сети): http://planka:1337
PLANKA_BASE_URL=http://planka:1337
# Ссылки в Issue (публичный URL)
PLANKA_PUBLIC_URL=https://board.averstech.ru
PLANKA_EMAIL=bridge@averstech.ru
PLANKA_PASSWORD=CHANGE_ME
# Токен = accessToken webhook в Admin UI Planka (Administration → Webhooks)
PLANKA_WEBHOOK_TOKEN=CHANGE_ME_random
PLANKA_READY_LIST_NAME=В работе (очередь Git)

# --- GitLab ---
GITLAB_BASE_URL=http://gitlab
GITLAB_TOKEN=glpat-CHANGE_ME
GITLAB_PROJECT_ID=
GITLAB_PROJECT_PATH=avers/AVERS
GITLAB_WEBHOOK_TOKEN=CHANGE_ME_random

# Опционально: явный маппинг username/email Planka → username GitLab
# PLANKA_GITLAB_USER_MAP={"ivan":"UBaHbI4"}
# По умолчанию сопоставление по email (и username, если совпадает).

# GitLab project path → метка Planka (иначе auto pr:{ProjectName})
# GITLAB_PROJECT_LABEL_MAP={"avers/front":"pr:Front","avers/plugins":"pr:Plugins"}

DATABASE_PATH=/data/bridge.db